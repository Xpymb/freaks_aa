# MinIO
MINIO_VERSION=RELEASE.2025-09-07T16-13-09Z
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=qwerty123
MINIO_REGION=us-east-1

# Centrifugo
CENTRIFUGO_VERSION=v6.6

# Keycloak
KEYCLOAK_ADMIN_CLIENT_SECRET=xxxxxxxxx